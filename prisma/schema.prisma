generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  bio       String?
  image     String?
  phone     String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model PracticeArea {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("practice_areas")
}

model TeamMember {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  title     String
  bio       String
  image     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("team_members")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  summary   String?
  image     String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("gallery_images")
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_requests")
}

model testimonials {
  id           String   @id @default(cuid())
  client_name  String
  client_title String?
  content      String
  rating       Int      @default(5)
  image        String?
  featured     Boolean  @default(false)
  order        Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime
}

model Career {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  department   String
  location     String
  type         String   @default("Full-time")
  description  String
  requirements String
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("careers")
}
